{
  "entities": {
    "UserProfile": {
      "title": "User Profile",
      "description": "Stores user-specific settings and profile information.",
      "type": "object",
      "properties": {
        "uid": { "type": "string", "description": "The unique identifier for the user." },
        "email": { "type": "string", "format": "email", "description": "The user's email address." },
        "displayName": { "type": "string", "description": "The user's display name." },
        "photoURL": { "type": "string", "format": "uri", "description": "The user's profile picture URL." },
        "theme": { "type": "string", "enum": ["light", "dark"], "description": "The user's preferred theme." },
        "createdAt": { "type": "string", "format": "date-time", "description": "When the profile was created." }
      },
      "required": ["uid", "email", "createdAt"]
    },
    "Expense": {
      "title": "Expense Record",
      "description": "A single expense entry recorded by the user.",
      "type": "object",
      "properties": {
        "id": { "type": "string", "description": "The unique identifier for the expense." },
        "uid": { "type": "string", "description": "The UID of the user who owns this expense." },
        "title": { "type": "string", "description": "The title of the expense (e.g., 'Groceries')." },
        "amount": { "type": "number", "description": "The amount spent." },
        "category": { "type": "string", "description": "The category of the expense (e.g., 'Food', 'Transport')." },
        "timestamp": { "type": "string", "format": "date-time", "description": "The date and time of the expense." },
        "location": {
          "type": "object",
          "properties": {
            "latitude": { "type": "number" },
            "longitude": { "type": "number" },
            "address": { "type": "string" }
          }
        },
        "createdAt": { "type": "string", "format": "date-time", "description": "When the record was created." }
      },
      "required": ["uid", "title", "amount", "category", "timestamp", "createdAt"]
    }
  },
  "firestore": {
    "/users/{uid}": {
      "schema": "UserProfile",
      "description": "User profile documents."
    },
    "/users/{uid}/expenses/{expenseId}": {
      "schema": "Expense",
      "description": "Subcollection of expenses for a specific user."
    }
  }
}
